# =====================================================================
# Server-only env vars (validated by lib/env.ts, marked import "server-only")
# Copy this file to .env and fill in the values. `bun run setup` will
# generate BETTER_AUTH_SECRET automatically if you leave it as the placeholder.
# =====================================================================

# SQLite/libsql connection string. Local dev uses `file:./local.db`; production
# uses `libsql://<your-db>.turso.io` with auth params.
DATABASE_URL=file:./local.db

# 32+ char random string used to sign session cookies. Generate with:
#   openssl rand -base64 32
# The setup script regenerates this placeholder on first run.
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Canonical URL of this app. Used by better-auth for callback URLs and by
# the public env schema. Use the deployed URL in production.
BETTER_AUTH_URL=http://localhost:3000

# development | test | production. Defaults to development if unset.
NODE_ENV=development

# =====================================================================
# Public env vars (validated by lib/public-env.ts, safe to expose to the
# client bundle. Must be prefixed NEXT_PUBLIC_.)
# =====================================================================

# Canonical URL exposed to the client. Must match BETTER_AUTH_URL in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
